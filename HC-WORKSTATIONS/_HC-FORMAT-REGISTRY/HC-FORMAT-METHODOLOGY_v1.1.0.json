  "namingConvention": {
    "pattern": "{CLASS}-HC-{SEQ}_{ShortTitle}_v{version}.{ext}",
    "example": "PLN-HC-0001_HIRECARPlan_v1.0.0.docx",
    "components": {
      "CLASS": "Two-letter document class code",
      "HC": "Literal HC identifier",
      "SEQ": "Four-digit zero-padded sequence number",
      "ShortTitle": "CamelCase title (no spaces)",
      "version": "Semantic version (v1.0.0)",
      "ext": "File extension"
    }
  },
